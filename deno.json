{
  "tasks": {
    "serve": "deno run --allow-net --allow-read main.ts",
    "build": "deno run -A npm:esbuild src/emulator.ts --bundle --outfile=public/bundle.js --format=esm",
    "dev":   "deno task build && deno task serve"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/http":   "jsr:@std/http@1"
  }
}
